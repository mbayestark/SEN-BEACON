NODE_ENV=development
PORT=5000

# MongoDB Connection
MONGODB_URI=mongodb://admin:devpassword123@mongodb:27017/hackathon?authSource=admin

# MongoDB Atlas (uncomment to use Atlas instead of local)
# MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/hackathon?retryWrites=true&w=majority

# Session Configuration
SESSION_SECRET=your-super-secret-session-key-change-in-production
SESSION_MAX_AGE=86400000

# CORS Configuration
CORS_ORIGIN=*

# Country Configuration
COUNTRY_CODE=RW
COUNTRY_TIMEZONE=Africa/Kigali
